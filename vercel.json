{
  "version": 2,
  "public": true,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://YOUR_RENDER_BACKEND_URL/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "frontend/$1"
    }
  ]
}
